<div class="max-w-sm mx-auto py-24">
    <div class="apple-card p-10 space-y-10 animate-fadeIn">
        <div class="space-y-2 text-center">
            <h1 class="text-2xl font-semibold tracking-tight text-[#1d1d1f]">Sign In</h1>
            <p class="text-[14px] text-[#86868b]">Access your secure document vault.</p>
        </div>

        <% if (error) { %>
            <div class="bg-rose-50 border border-rose-100 p-4 text-rose-500 text-[13px] text-center rounded-2xl">
                <%= error %>
            </div>
        <% } %>

        <form action="/api/auth/login" method="POST" class="space-y-6" id="loginForm">
            <div class="space-y-4">
                <div class="space-y-1.5 px-1">
                    <label class="text-[12px] font-medium text-[#1d1d1f]">Email address</label>
                    <input type="email" name="email" required placeholder="name@example.com" class="w-full">
                </div>
                <div class="space-y-1.5 px-1">
                    <label class="text-[12px] font-medium text-[#1d1d1f]">Password</label>
                    <input type="password" name="password" required placeholder="••••••••" class="w-full">
                </div>
            </div>
            <button type="submit" class="bg-[#1d1d1f] text-white w-full py-3.5 rounded-full text-[14px] font-medium hover:opacity-90 transition-opacity">Sign In</button>
        </form>

        <div class="pt-6 border-t border-[#d2d2d7]/30 text-center">
            <p class="text-[13px] text-[#86868b]">
                New to KamiVault? <a href="/signup" class="text-apple-blue hover:underline">Create an account</a>
            </p>
        </div>
    </div>
</div>

<script>
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        try {
            const res = await fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (res.ok) {
                if (result.requires2FA) {
                    window.location.href = '/verify-2fa';
                } else {
                    window.location.href = '/vault';
                }
            } else {
                alert(result.error);
            }
        } catch (err) { console.error(err); }
    });
</script>
