<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-3xl border border-brand-accent/30 shadow-xl">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Create Account</h1>
        <p class="text-gray-500">Join the <span class="text-brand font-bold">KamiVault</span> family</p>
    </div>

    <% if (error) { %>
        <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-6 flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-sm font-medium"><%= error %></span>
        </div>
    <% } %>

    <form action="/signup" method="POST" class="space-y-6">
        <div>
            <label for="name" class="block text-sm font-bold text-gray-700 mb-2">Full Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe"
                class="w-full px-4 py-3 bg-brand-light/50 border border-transparent focus:border-brand-accent focus:bg-white rounded-xl outline-none transition-all placeholder:text-gray-400">
        </div>
        <div>
            <label for="email" class="block text-sm font-bold text-gray-700 mb-2">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="name@example.com"
                class="w-full px-4 py-3 bg-brand-light/50 border border-transparent focus:border-brand-accent focus:bg-white rounded-xl outline-none transition-all placeholder:text-gray-400">
        </div>
        <div>
            <label for="password" class="block text-sm font-bold text-gray-700 mb-2">Create Password</label>
            <input type="password" id="password" name="password" required placeholder="••••••••"
                class="w-full px-4 py-3 bg-brand-light/50 border border-transparent focus:border-brand-accent focus:bg-white rounded-xl outline-none transition-all placeholder:text-gray-400">
        </div>
        
        <p class="text-xs text-gray-400 leading-relaxed px-1">
            By creating an account, you agree to our 
            <a href="#" class="text-brand font-medium hover:underline">Terms of Service</a> and 
            <a href="#" class="text-brand font-medium hover:underline">Privacy Policy</a>.
        </p>

        <button type="submit" class="w-full py-4 bg-brand hover:bg-brand-dark text-white rounded-xl font-bold shadow-lg shadow-brand/20 transition-all active:scale-95">
            Get Started
        </button>
    </form>

    <div class="mt-10 pt-6 border-t border-gray-100 text-center">
        <p class="text-gray-500">Already have an account? 
            <a href="/login" class="text-brand font-bold hover:underline">Log In</a>
        </p>
    </div>
</div>
