<div class="max-w-2xl mx-auto space-y-16 animate-fadeIn">
    <div class="space-y-1">
        <h1 class="text-4xl font-semibold tracking-tight text-[#1d1d1f]">Settings</h1>
        <p class="text-[15px] font-normal text-[#86868b]">Project-wide configuration and identity.</p>
    </div>

    <div class="space-y-12">
        <section class="space-y-6">
            <h3 class="text-lg font-semibold text-[#1d1d1f]">Identity</h3>
            <div class="apple-card p-8 grid md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label class="text-[12px] font-medium text-[#86868b]">Display name</label>
                    <p class="text-[15px] font-medium text-[#1d1d1f] px-4 py-3 bg-[#f5f5f7] rounded-xl"><%= locals.userName %></p>
                </div>
                <div class="space-y-2">
                    <label class="text-[12px] font-medium text-[#86868b]">Email address</label>
                    <p class="text-[15px] font-medium text-[#1d1d1f] px-4 py-3 bg-[#f5f5f7] rounded-xl"><%= locals.userEmail %></p>
                </div>
            </div>
        </section>

        <section class="space-y-6">
            <h3 class="text-lg font-semibold text-[#1d1d1f]">Security</h3>
            <div class="apple-card p-8 flex items-center justify-between">
                <div class="space-y-1">
                    <p class="text-[15px] font-medium text-[#1d1d1f]">Binary Access Control</p>
                    <p class="text-[13px] text-[#86868b]">Enforce private MinIO bucket isolation.</p>
                </div>
                <div class="w-10 h-5 bg-[#34c759] rounded-full relative">
                    <div class="absolute right-0.5 top-0.5 w-4 h-4 bg-white rounded-full shadow-sm"></div>
                </div>
            </div>
        </section>
    </div>
</div>
