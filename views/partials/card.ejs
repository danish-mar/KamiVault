<div class="bg-white p-6 rounded-2xl shadow-sm border border-brand-accent/50 hover:shadow-md hover:border-brand/30 transition-all group">
    <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand transition-colors"><%= name %></h3>
    <p class="text-gray-600 mb-4"><%= description %></p>
    <div class="flex justify-between items-center text-xs text-brand-dark/60 font-medium italic">
        <span>Added: <%= new Date(createdAt).toLocaleDateString() %></span>
        <button class="text-brand hover:text-brand-dark font-bold underline decoration-brand-accent">View Details</button>
    </div>
</div>
